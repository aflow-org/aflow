{
  "version": 2,
  "configurePresets": [
    {
      "name": "MyConfigPreset",
      "inherits": ["common", "vcpkg", "debug_setting"],
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      },
      "environment": {
        "VCPKG_ROOT": "/home/me/.vcpkg/vcpkg"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "MyBuildPreset",
      "configurePreset": "MyConfigPreset",
      "jobs": 8
    }
  ]
}